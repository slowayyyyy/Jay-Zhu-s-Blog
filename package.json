{
  "name": "jay-zhus-blog",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --background --force",
    "dev:stop": "astro dev stop",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "cms": "decap-server",
    "admin": "astro dev stop && astro dev --background --force && decap-server",
    "build": "astro sync --force && astro build && node scripts/verify-content.mjs",
    "verify:content": "node scripts/verify-content.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "decap-server": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
