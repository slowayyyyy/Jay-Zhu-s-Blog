---
import {
	estimateReadingMinutes,
	formatDate,
	getPostSlug,
	getSectionInfo,
	getTagLabel,
	getTagMap,
	type PostEntry,
} from '../lib/content';

interface Props {
	post: PostEntry;
}

const { post } = Astro.props;
const section = getSectionInfo(post.data.section);
const readingMinutes = estimateReadingMinutes(post);
const slug = getPostSlug(post);
const tagMap = await getTagMap();
---

<article class="post-card glass-card">
	<div class="post-card-top">
		<span class="section-chip" style={`--chip-accent:${section.accent};`}>
			<span class="chip-dot" />
			<span data-copy={`section.${post.data.section}`}>{section.zh}</span>
		</span>
		<time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
	</div>
	<h3 class="post-title">
		<a href={`/posts/${slug}/`}>{post.data.title}</a>
	</h3>
	<p class="post-description">{post.data.excerpt}</p>
	<div class="post-meta">
		<span>{readingMinutes} min</span>
		<div class="post-tags">
			{
				post.data.tags.slice(0, 3).map((tag) => (
					<a class="tag-chip" href={`/search/?tag=${encodeURIComponent(tag)}`}>
						#{getTagLabel(tag, tagMap)}
					</a>
				))
			}
		</div>
	</div>
	<a class="read-link" href={`/posts/${slug}/`} data-copy="common.readMore" />
</article>

<style>
	.post-card {
		padding: 1.5rem;
		border-radius: var(--radius-xl);
		transform: translateZ(0) scale(1);
		transition:
			transform 320ms cubic-bezier(0.2, 0.75, 0.25, 1),
			box-shadow 320ms ease,
			border-color 320ms ease;
		will-change: transform;
	}

	.post-card:hover {
		transform: translateY(-6px) scale(1.018);
		border-color: color-mix(in srgb, var(--accent) 24%, var(--line));
		box-shadow: 0 24px 64px rgba(45, 67, 87, 0.14);
	}

	.post-card-top {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		font-size: 0.84rem;
		color: var(--text-soft);
	}

	.section-chip {
		border-color: color-mix(in srgb, var(--chip-accent) 28%, transparent);
		background: color-mix(in srgb, var(--chip-accent) 12%, transparent);
	}

	.chip-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--chip-accent);
	}

	.post-title {
		margin: 1rem 0 0.8rem;
		font-family: var(--font-serif);
		font-size: clamp(1.4rem, 3vw, 2rem);
		line-height: 1.12;
		letter-spacing: -0.04em;
	}

	.post-title a:hover {
		color: var(--accent);
	}

	.post-description {
		margin: 0;
		color: var(--text-soft);
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		margin-top: 1.1rem;
		color: var(--text-soft);
		font-size: 0.92rem;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.read-link {
		display: inline-flex;
		margin-top: 1.15rem;
		color: var(--accent);
	}
</style>
