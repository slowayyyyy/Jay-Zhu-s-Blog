---
import type { CollectionEntry } from 'astro:content';
import { renderMarkdownContent } from '../lib/markdown';
import { getTagLabel, getTagMap } from '../lib/content';

interface Props {
	checkins: CollectionEntry<'checkins'>[];
}

const { checkins } = Astro.props;
const tagMap = await getTagMap();
const renderedBodies = new Map(
	await Promise.all(
		checkins.map(async (checkin) => [
			checkin.id,
			(await renderMarkdownContent(checkin.body ?? '', checkin.data)).code.trim(),
		] as const),
	),
);
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
});

const timeFormatter = new Intl.DateTimeFormat('zh-CN', {
	hour: '2-digit',
	minute: '2-digit',
	hour12: false,
});

const formatDate = (date: Date) => {
	const dateLabel = dateFormatter.format(date).replaceAll('/', ' / ');
	const hasTime = date.getHours() !== 0 || date.getMinutes() !== 0;
	return hasTime ? `${dateLabel} · ${timeFormatter.format(date)}` : dateLabel;
};
---

<section class="daily-checkins container" aria-labelledby="daily-checkin-title">
	<div class="checkin-heading">
		<div>
			<div class="eyebrow" data-copy="checkins.kicker">DAILY LOG</div>
			<h1 class="section-title" id="daily-checkin-title" data-copy="checkins.title">每日打卡</h1>
		</div>
		<p class="checkin-intro" data-copy="checkins.intro">
			用最短的文字，留下今天确实做过的事。
		</p>
	</div>

	<div class="checkin-board glass-card">
		<div class="board-topline">
			<span class="board-mark" aria-hidden="true">✓</span>
			<span data-copy="checkins.listTitle">全部记录</span>
			<span class="board-count">{String(checkins.length).padStart(2, '0')}</span>
		</div>
		<div class="checkin-list">
			{
				checkins.map((checkin) => (
					<article class="checkin-entry">
						<time datetime={checkin.data.date.toISOString()}>{formatDate(checkin.data.date)}</time>
						<div class="checkin-content">
							<h3>{checkin.data.title}</h3>
							{checkin.data.summary && <p class="checkin-summary">{checkin.data.summary}</p>}
							{
								renderedBodies.get(checkin.id) && (
									<div class="checkin-body prose prose-compact" set:html={renderedBodies.get(checkin.id)} />
								)
							}
							{checkin.data.items.length > 0 && (
								<dl class="checkin-details">
									{checkin.data.items.map((item) => (
										<div>
											<dt>{item.label}</dt>
											<dd>
												{item.href ? (
													<a href={item.href} target="_blank" rel="noreferrer">
														{item.value}<span aria-hidden="true"> ↗</span>
													</a>
												) : (
													item.value
												)}
											</dd>
										</div>
									))}
								</dl>
							)}
							<div class="checkin-tags">
								{checkin.data.tags.map((tag) => <span>#{getTagLabel(tag, tagMap)}</span>)}
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.daily-checkins {
		padding: 2.2rem 0 2.5rem;
		animation: checkin-rise 720ms 240ms both;
	}

	.checkin-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 1.15rem;
	}

	.checkin-heading .section-title {
		margin-top: 0.4rem;
	}

	.checkin-intro {
		max-width: 25rem;
		margin: 0 0 0.25rem;
		color: var(--text-soft);
		text-align: right;
	}

	.checkin-board {
		padding: 0 1.6rem;
		border-radius: var(--radius-xl);
	}

	.board-topline {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--line);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
		color: var(--text-soft);
	}

	.board-mark {
		display: grid;
		place-items: center;
		width: 1.65rem;
		height: 1.65rem;
		border-radius: 50%;
		background: color-mix(in srgb, var(--accent) 12%, white);
		color: var(--accent);
		font-weight: 700;
	}

	.board-count {
		font-family: var(--font-serif);
		font-size: 1rem;
		color: var(--accent);
	}

	.checkin-entry {
		display: grid;
		grid-template-columns: 8rem minmax(0, 1fr);
		gap: 1.75rem;
		padding: 1.65rem 0;
		border-bottom: 1px solid var(--line);
	}

	.checkin-entry:last-child {
		border-bottom: 0;
	}

	.checkin-entry time {
		padding-top: 0.25rem;
		color: var(--text-soft);
		font-family: var(--font-serif);
		font-size: 0.86rem;
		font-style: italic;
		letter-spacing: 0.04em;
	}

	.checkin-content h3 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: 1.28rem;
		line-height: 1.35;
	}

	.checkin-summary {
		margin: 0.32rem 0 0;
		color: var(--text-soft);
	}

	.checkin-body {
		margin-top: 0.85rem;
	}

	.checkin-body :global(p:first-child) {
		margin-top: 0;
	}

	.checkin-body :global(p:last-child),
	.checkin-body :global(ul:last-child),
	.checkin-body :global(ol:last-child),
	.checkin-body :global(blockquote:last-child) {
		margin-bottom: 0;
	}

	.checkin-details {
		display: grid;
		gap: 0.35rem;
		margin: 0.85rem 0 0;
		font-size: 0.94rem;
	}

	.checkin-details > div {
		display: grid;
		grid-template-columns: 6rem minmax(0, 1fr);
		gap: 0.75rem;
	}

	.checkin-details dt {
		color: var(--text-soft);
	}

	.checkin-details dd {
		margin: 0;
	}

	.checkin-details a,
	.checkin-tags {
		color: var(--accent);
	}

	.checkin-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 0.8rem;
		font-size: 0.82rem;
	}

	@keyframes checkin-rise {
		from { opacity: 0; transform: translateY(22px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 680px) {
		.checkin-heading {
			display: block;
		}

		.checkin-intro {
			margin-top: 0.7rem;
			text-align: left;
		}

		.checkin-board {
			padding: 0 1rem;
		}

		.checkin-entry {
			grid-template-columns: 1fr;
			gap: 0.55rem;
		}

		.checkin-details > div {
			grid-template-columns: 4.8rem minmax(0, 1fr);
		}
	}
</style>
